---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
const base = import.meta.env.BASE_URL;
// Neutrales Fallback: alphabetisch; per JS wird bei jedem Aufruf gemischt
const korporationen = (await getCollection('korporationen')).sort((a, b) =>
  a.data.name.localeCompare(b.data.name, 'de')
);
---
<Base title="Korporationen">
  <section class="section">
    <div class="container">
      <span class="eyebrow">Wir sind die KGN</span>
      <h1>Unsere Korporationen</h1>
      <p class="prose">
        Die KG Niedermendig 1897 e.V. lebt durch ihre Korporationen – jede mit eigenem Charakter,
        alle mit demselben Ziel: den Mendiger Karneval unvergesslich zu machen.
      </p>
      <div class="korp-liste" data-shuffle>
        {korporationen.map((k) => (
          <div class="korp-zeile card" style={`--akzent: ${k.data.farbe}`}>
            <a href={`${base}korporationen/${k.id}/`} class="korp-zeile-link">
              <span class="korp-media">
                {k.data.logo ? (
                  <img class="korp-logo" src={`${base}${k.data.logo.replace(/^\//, '')}`} alt="" loading="lazy" />
                ) : (
                  <span class="korp-badge" aria-hidden="true">{(k.data.kurzname ?? k.data.name).charAt(0)}</span>
                )}
              </span>
              <div class="korp-text">
                <h2>{k.data.name}</h2>
                <p>{k.data.claim}</p>
              </div>
              <span class="korp-mehr">Mehr erfahren →</span>
            </a>
            {(k.data.externe_url || k.data.instagram || k.data.youtube) && (
              <div class="korp-social-mini">
                {k.data.externe_url && (
                  <a href={k.data.externe_url} target="_blank" rel="noopener">Website ↗</a>
                )}
                {k.data.instagram && (
                  <a href={`https://www.instagram.com/${k.data.instagram}/`} target="_blank" rel="noopener">Instagram ↗</a>
                )}
                {k.data.youtube && (
                  <a href={k.data.youtube} target="_blank" rel="noopener">YouTube ↗</a>
                )}
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .korp-liste { display: grid; gap: 1.2rem; margin-top: 2.5rem; }
  .korp-zeile {
    padding: 1.6rem 2rem;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .korp-zeile:has(.korp-zeile-link:hover) {
    transform: translateX(6px);
    box-shadow: 0 12px 32px color-mix(in srgb, var(--akzent) 22%, transparent);
    outline: 1px solid color-mix(in srgb, var(--akzent) 35%, transparent);
  }
  .korp-zeile-link {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    text-decoration: none;
    color: var(--tinte);
  }
  .korp-media {
    flex: none;
    width: 120px;
    height: 72px;
    display: grid;
    place-items: center;
    border-radius: 14px;
    background: color-mix(in srgb, var(--akzent) 9%, transparent);
  }
  .korp-zeile-link:hover .korp-media {
    background: color-mix(in srgb, var(--akzent) 16%, transparent);
  }
  @media (prefers-color-scheme: dark) {
    /* Logos brauchen im Dunkeln eine helle Flaeche (z. B. dunkelblaue Wortmarken) */
    .korp-media:has(.korp-logo) {
      background: color-mix(in srgb, var(--akzent) 10%, #fff);
    }
    .korp-zeile-link:hover .korp-media:has(.korp-logo) {
      background: color-mix(in srgb, var(--akzent) 18%, #fff);
    }
  }
  .korp-logo {
    max-height: 60px;
    max-width: 108px;
    object-fit: contain;
  }
  .korp-badge {
    width: 54px;
    height: 54px;
    border-radius: 14px;
    display: grid;
    place-items: center;
    background: var(--akzent);
    color: #fff;
    font-weight: 850;
    font-size: 1.5rem;
    box-shadow: 0 4px 14px color-mix(in srgb, var(--akzent) 35%, transparent);
  }
  .korp-text { flex: 1; }
  .korp-zeile h2 { font-size: 1.4rem; margin-bottom: 0.2rem; }
  .korp-zeile p { margin: 0; color: var(--tinte-soft); }
  .korp-mehr { font-weight: 700; color: var(--kgn-rot); white-space: nowrap; }
  .korp-social-mini {
    display: flex;
    gap: 1.2rem;
    margin-top: 0.9rem;
    padding-top: 0.9rem;
    border-top: 1px solid var(--linie);
    padding-left: calc(120px + 1.5rem);
  }
  .korp-social-mini a {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--tinte-soft);
    text-decoration: none;
  }
  .korp-social-mini a:hover { color: var(--kgn-rot); }
  @media (max-width: 600px) {
    .korp-zeile-link { flex-direction: column; align-items: flex-start; }
    .korp-social-mini { padding-left: 0; }
  }
</style>

<script>
  document.querySelectorAll('[data-shuffle]').forEach((el) => {
    const kinder = Array.from(el.children);
    for (let i = kinder.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [kinder[i], kinder[j]] = [kinder[j], kinder[i]];
    }
    kinder.forEach((k) => el.appendChild(k));
  });
</script>
