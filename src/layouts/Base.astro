---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Karnevalsgesellschaft Niedermendig 1897 e.V. – Sitzungskarneval, Korporationen und Termine aus Mendig.' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · KG Niedermendig 1897 e.V.</title>
    <meta name="description" content={description} />
    {/* Staging: nicht indexieren, bis die Site live auf karneval-in-mendig.de läuft */}
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/png" href={`${base}images/logos/kgn-jester-color.png`} />
  </head>
  <body>
    <Header />
    <main><slot /></main>
    <Footer />
  </body>
</html>
